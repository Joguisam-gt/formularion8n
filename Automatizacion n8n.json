      "parameters": {
        "jsCode": "// 1. Capturar la estructura nativa del mensaje o del callback de Telegram\nconst message = $input.item.json.message || {};\nconst callbackQuery = $input.item.json.callback_query || {};\nconst from = message.from || callbackQuery.from || {};\n\n// 2. Extraer datos del usuario\nconst telegramUserId = from.id || \"\";\nconst firstName = from.first_name || \"Usuario\";\n\n// 3. Determinar el texto entrante (si fue escrito o si fue un botón)\nlet textContent = message.text || \"\";\nlet esCallback = false;\n\nif (callbackQuery.data) {\n  textContent = callbackQuery.data; // Ej: 'reportar_falta' o 'consultar_tramite'\n  esCallback = true;\n}\n\n// 4. Detectar si contiene archivos multimedia\nconst hasVoice = !!(message.voice || message.audio);\nconst hasPhoto = !!(message.photo || message.document);\n\nreturn {\n  json: {\n    telegram_user_id: telegramUserId,\n    user_name: firstName,\n    texto_puro: textContent.trim(),\n    es_comando_start: textContent.trim() === '/start',\n    es_callback: esCallback,\n    es_audio: hasVoice,\n    es_foto: hasPhoto\n  }\n};"
      },
