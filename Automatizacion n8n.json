        "jsCode": "// 1. Capturar los datos del usuario que vienen arrastrándose en el flujo\n// Usamos el operador opcional ?. para evitar errores si algún campo falta\nconst telegramUserId = $('Code in JavaScript').item?.json?.telegram_user_id || \"\";\nconst userName = $('Code in JavaScript').item?.json?.user_name || \"Usuario\";\n\n// 2. Generar un ID Alfanumérico Único (Formato: ATH-XXXXX)\nconst caracteres = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';\nlet codigoAleatorio = '';\nfor (let i = 0; i < 5; i++) {\n  codigoAleatorio += caracteres.charAt(Math.floor(Math.random() * caracteres.length));\n}\n\n// Combinamos el prefijo del proyecto (AetherIA) con el código aleatorio\nconst idInstitucional = `ATH-${codigoAleatorio}`;\n\n// 3. Retornar el payload limpio para la base de datos\nreturn {\n  json: {\n    id_registro: idInstitucional,\n    telegram_user_id: telegramUserId,\n    nombre_completo: userName,\n    rol: \"Pendiente\", // Se inicializa como pendiente para asignación manual o posterior\n    estado: \"Activo\"\n  }\n};"
      },
