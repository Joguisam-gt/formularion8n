        "jsCode": "// 1. Fabricar el ID único con el año actual\nconst anioActual = new Date().getFullYear();\nconst numeroAleatorio = Math.floor(1000 + Math.random() * 9000); \nconst idGestionado = `AETHER-${anioActual}-TG${numeroAleatorio}`;\n\n// 2. Fabricar la fecha de hoy de forma automática\nconst hoy = new Date();\nconst fechaFormato = hoy.toLocaleDateString('es-GT', {\n  day: '2-digit',\n  month: '2-digit',\n  year: 'numeric'\n});\nconst horaFormato = hoy.toLocaleTimeString('es-GT', {\n  hour: '2-digit',\n  minute: '2-digit'\n});\n\n// 3. Capturar lo que venía de Telegram de forma segura\nconst datosTelegram = $input.item?.json || {};\n\n// 4. Devolver TODO unido en un solo paquete estructurado\nreturn {\n  json: {\n    telegram_original: datosTelegram, // Guarda aquí todo lo de Telegram por seguridad\n    numero_gestion: idGestionado,     // Aquí nace tu número de caso\n    fecha_reporte: fechaFormato,       // Aquí nace la fecha de hoy\n    hora_reporte: horaFormato          // Aquí nace la hora de hoy\n  }\n};"
      },
